{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mypy type tests"
            "type": "shell",
            "command": "mypy --ignore-missing-imports --explicit-package-bases .",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "pytest unit",
            "type": "shell",
            "command": "cd tests/unit; PYTHONPATH=../..: pytest",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "pytest integration",
            "type": "shell",
            "command": "cd tests/integration; PYTHONPATH=../..: pytest -m sqlite3 -vv",
            "problemMatcher": []
        },
        {
            "label": "pytest integration last failed",
            "type": "shell",
            "command": "cd tests/integration; PYTHONPATH=../..: pytest -m sqlite3 -vv --last-failed",
            "problemMatcher": []
        },
        {
            "label": "pytest e2e",
            "type": "shell",
            "command": "cd tests/e2e; PYTHONPATH=../..: pytest -m sqlite3 -vv",
            "problemMatcher": []
        },
        {
            "label": "pytest all",
            "dependsOn": [
                "pytest unit",
                "pytest integration"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "ruff format",
            "type": "shell",
            "command": "ruff format",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "ruff check fix",
            "type": "shell",
            "command": "ruff check --fix",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "ruff all",
            "dependsOn": [
                "ruff format",
                "ruff check"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "ci all",
            "dependsOn": [
                "ruff all",
                "pytest all"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "run flask",
            "type": "shell",
            "command": "flask run --debug --host=0.0.0.0 --port=5000",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
